{
  "name": "revitreez",
  "version": "0.0.2",
  "private": true,
  "description": "Revitreez is boilerplate web application built with React, Vite, TypeScript, Tailwind CSS, TanStack Router, and TanStack Query.",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "tsc -b && bunx --bun vite build",
    "build:analyze": "ANALYZE=true bun run build",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "preview": "bunx --bun vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "^0.9.10",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-form-devtools": "^0.2.17",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.166.2",
    "@tanstack/react-router-devtools": "^1.166.2",
    "@toolwind/corner-shape": "^0.0.8-3",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.166.2",
    "@types/bun": "^1.3.10",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
